search_vendor() {
	ensure_oui_list &&

	local -a prefixes=()
	local -A vendor_by_prefix=()
	local regex filtered_cache line json bssid prefix vendor do_export FILTERED_FMT
	MATCHING_COUNT=0
	if [ ! -f "$CACHE_FILE" ]; then
		error "Cache file not found. Try to scan first."
		exit 1
	fi
	if [ ! -f "$OUI_FILE" ]; then
		error "OUI file not found."
		exit 1
	fi
	if [ -z "$SEARCH_VENDOR" ] || ! [[ "$SEARCH_VENDOR" =~ [^[:space:]] ]]; then
		error "Search vendor is empty."
		exit 1
	fi
	while IFS=$'\t' read -r prefix vendor; do
		[ -n "$prefix" ] || continue
		[ -n "$vendor" ] || continue
		if [ -z "${vendor_by_prefix[$prefix]+x}" ]; then
			vendor_by_prefix["$prefix"]="$vendor"
			prefixes+=("$prefix")
		fi
	done < <(
		awk -F',' -v needle="$SEARCH_VENDOR" '
			function trim(s) {
				gsub(/^[ \t]+|[ \t]+$/, "", s)
				return s
			}
			{
				p = trim($1)
				v = substr($0, index($0, ",") + 1)
				v = trim(v)
				if (index(tolower(v), tolower(needle)) > 0) {
					printf "%s\t%s\n", toupper(p), v
				}
			}
		' "$OUI_FILE"
	)

	if [ "${#prefixes[@]}" -eq 0 ]; then
		error "No vendors found."
		exit 1
	fi

	regex=$(printf "%s|" "${prefixes[@]}")
	regex=${regex%|}

	info "Search vendor: $(printf '\033[38;5;14m\033[1m%s\033[0m' "$SEARCH_VENDOR")"

	filtered_cache=$(mktemp) || {
		error "Failed to create temp file."
		exit 1
	}

	if ! grep -Ei "\"bssid\":\"(${regex})" "$CACHE_FILE" > "$filtered_cache"; then
		rm -f "$filtered_cache"
		error "No matches found."
		exit 1
	fi

	while IFS= read -r line; do
		echo
		info "Found:"
		if ! json=$(printf "%s" "$line" | jq . 2>/dev/null); then
			rm -f "$filtered_cache"
			error "Failed to parse JSON."
			exit 1
		fi

		bssid=$(printf "%s" "$json" | jq -r '.bssid // empty')
		prefix=${bssid^^}
		prefix=${prefix:0:8}
		vendor=${vendor_by_prefix[$prefix]}

		info "$(printf 'Vendor: \033[38;5;14m%s\033[0m' "$vendor")"
		printf "%s\n" "$json"
		MATCHING_COUNT=$((MATCHING_COUNT+1))
	done < "$filtered_cache"

	echo
	info "Search vendor: $(printf '\033[38;5;14m\033[1m%s\033[0m' "$SEARCH_VENDOR")"
	info "Matching: $MATCHING_COUNT"
	stty echo
	info "Export found data? [y/N] "
	read -rn1 do_export
	stty -echo
	case "$do_export" in
		y)
			stty echo
			echo -en "\e[?25h`info "Select output format (json|jsonl|pjson|csv|kml): "`"
			read -r FILTERED_FMT
			stty -echo
			echo -en "\e[?25l"
			do_save "$filtered_cache" "$FILTERED_FMT"
			;;
		*)
			info "Selected: $do_export"
			info "Aborting."
			;;
	esac

	rm -f "$filtered_cache"
	success "Done."
	exit 0
}
merge_kml() {
	if ! $DO_MERGE; then
		error "Something went wrong..."
		exit 1
	fi

	if [ -z "$MERGE_1" ] || [ -z "$MERGE_2" ]; then
		error "Something went wrong..."
		exit 1
	fi
	
	if ! command -v python3 &>/dev/null; then
		error "Dependent command 'python' not found."
		exit 1
	fi
	if [ ! -x `which python3` ]; then
		error "$SCRIPT_COMMAND: Permission denied: `which python3`"
		exit 1
	fi
	
	for f in "$MERGE_1" "$MERGE_2"; do
		[ -f "$f" ] || {
			error "File $f does not exist."
			exit 1
		}
		[ -r "$f" ] || {
			error "$SCRIPT_COMMAND: Permission denied: $f"
			exit 1
		}
	done

	for f in "$MERGE_1" "$MERGE_2"; do
		info "Checking file: $f"
		VALID_FILE="$f"
		valid noex >/dev/null || {
			error "File $f is invalid..."
			exit 1
		}
	done

	base1="$(basename "$MERGE_1")"
	base2="$(basename "$MERGE_2")"
	name1="${base1%.*}"
	name2="${base2%.*}"
	OUTPUT_MERGE="${name1}_${name2}.kml"

	if [[ -e "$OUTPUT_MERGE" ]]; then
		OUTPUT_MERGE="${name1}_${name2}-$(date +%s).kml"
	fi
	
	python3 - "$MERGE_1" "$MERGE_2" "$OUTPUT_MERGE" <<'PY'
import sys
import xml.etree.ElementTree as ET

in1, in2, out = sys.argv[1:]

NS = 'http://www.opengis.net/kml/2.2'
ET.register_namespace('', NS)

def q(tag):
	return f'{{{NS}}}{tag}'

def local(tag):
	return tag.rsplit('}', 1)[-1] if tag.startswith('{') else tag

def info(*parts):
	sys.stdout.write(f"\r\033[1;33m[INFO]\033[0m {' '.join(str(p) for p in parts)}\033[K\n")

def err(*parts):
	sys.stderr.write(f"\r\033[1;31m[ERR!]\033[0m {' '.join(str(p) for p in parts)}\033[K\n")

def fail(*parts):
	err(*parts)
	raise SystemExit(1)

def parse(path):
	try:
		tree = ET.parse(path)
	except ET.ParseError as e:
		fail(f'{path}: XML error: {e}')

	root = tree.getroot()
	if local(root.tag) != 'kml':
		fail(f'{path}: not a KML file')

	doc = root.find(q('Document'))
	if doc is None:
		fail(f'{path}: missing Document')

	placemarks = doc.findall(q('Placemark'))
	if not placemarks:
		fail(f'{path}: no Placemark elements found')

	sig = [local(c.tag) for c in placemarks[0]]
	for idx, pm in enumerate(placemarks[1:], 2):
		cur = [local(c.tag) for c in pm]
		if cur != sig:
			fail(f'{path}: Placemark #{idx} has a different structure than the first one')

	return tree, root, doc, placemarks, sig

def style_ids(doc):
	return {el.get('id') for el in doc.findall(q('Style')) if el.get('id')}

def key(pm):
