			CACHE*)
				JSON_LIST=false
				info "Select operation:"
				menu_select CACHE_OP "List in pretty format [slow]" "List in JSON [fast]" "Count data records" "Search for patterns" "Search for vendor" "Purge all database contents" ABORT
				case "$CACHE_OP" in
					List\ in\ pretty*) success "Listing..."; list_cache ;;
					List\ in\ JSON*) success "Listing..."; JSON_LIST=true; list_cache ;;
					Count*) success "Counting..."; count_cache; exit 0 ;;
					Search\ for\ pat*)
						info "Enter search patterns one-by-one bellow."
