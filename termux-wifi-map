banner() {
	$SHOW_BANNER || return 0
	stty -echo
	if [ -p /proc/$$/fd/1 ]; then
		echo -e "${RED}[WARN]${RESET} output redirected : banner skipped" >&2
		return 0
	fi
	if [ -p /proc/$$/fd/2 ]; then
		echo -e "${RED}[WARN]${RESET} output redirected : banner skipped" >&2
		return 0
	fi
	if [ -n "$SSH_TTY" ] && [[ "$SSH_TTY" == "$(tty)" ]]; then
		echo -e "${RED}[WARN]${RESET} ssh connection : banner skipped" >&2
		echo -e "${RED}[WARN]${RESET} Most SSH clients do not properly handle ANSI escapes (which this script uses), which can result in unreadable output." >&2
		return 0
	fi
	local c_point="\e[22m\e[1;31m"; local c_stand="\e[0m\e[2m"
	local c_st1="\e[8m"; local c_st2="\e[8m"; local c_st3="\e[8m"
	frame() {
		echo -e "\e[?7l                  ${c_st3}_. $RESET		$SCRIPT_NAME (c) $SCRIPT_V_R_DATE
             ${c_st2} _.  ${c_st3}\\ \\ $RESET		Made by $SCRIPT_AUTHOR
   ${c_point},––,   ${c_st1}_. ${c_st2} \\ \\  ${c_st3}\\ \\ $RESET
  ${c_point}/    \\  ${c_st1}\\ \\. ${c_st2}\\ \\. ${c_st3}\\ \\. $RESET	An extensive and automated OSINT
  ${c_point}\\ () /   ${c_st1}} }  ${c_st2}} }  ${c_st3}} } $RESET	tool for collecting data from
   ${c_point}\\  /   ${c_st1}/_/‘ ${c_st2}/ /‘ ${c_st3}/ /‘ $RESET	Access Points in your area!
  ${c_stand}/ ${c_point}\\/ ${c_stand}\\      ${c_st2}/_/  ${c_st3}/ / $RESET
  ${c_stand}\____/          ${c_st3}/_/ $RESET		v$SCRIPT_VERSION
\e[?7h"
	}
	frame; echo -en "\e[9A"; sleep 0.2
	c_st1="\e[1;31m"
	frame; echo -en "\e[9A"; sleep 0.2
	c_st1="\e[0m\e[1;33m"; c_st2="\e[0m\e[1;33m"
	frame; echo -en "\e[9A"; sleep 0.2
	c_st1="\e[0m\e[1;32m"; c_st2="\e[0m\e[1;32m"; c_st3="\e[0m\e[1;32m"
	frame; echo -en "\e[9A"; sleep 0.25
	echo -en "\e[8B"
}
check_update() {
	$1 && {
		if (( RANDOM % 2)); then
			return 0
		fi
	}
	SCRIPT_AV_VERSION="$(timeout 3 curl -s "$SCRIPT_RAW_REPO" | grep -oP '^SCRIPT_VERSION="\K[^"]+')"
	if [ -t 1 ] && version_lt "$SCRIPT_VERSION" "$SCRIPT_AV_VERSION"; then	
		echo -e "\e[1;5;32m[UPDATE]\e[0m New version of the script available: $SCRIPT_AV_VERSION
Check the details: \e[1;36m$SCRIPT_PAGE\e[0m\e[K
                   \e[1;36mhttps://github.com/BuriXon-code/$SCRIPT_NAME/\e[0m\e[K" >&2
	else
		$2 && {
			info "You are currently using the latest version."
			return 0
		} || {
			return 0
		}
	fi
}
version_info() {
	if [ -p /proc/$$/fd/1 ]; then
		echo -en "\e[1A$SCRIPT_NAME v$SCRIPT_VERSION (c) $SCRIPT_V_R_DATE $SCRIPT_AUTHOR"
	else
		info "$SCRIPT_NAME v$SCRIPT_VERSION (c) $SCRIPT_V_R_DATE $SCRIPT_AUTHOR"
		check_update true false
	fi
}
