						PATTERNS=""
						CYCLE=1
						until [ "$CYCLE" -gt 10 ]; do
							ERROR=false
							stty echo
							echo -en "\e[?25h\r\e[1;33m[INFO]\e[0m Enter phrase to find: \e[K"
							IFS=" " read -r PHRASE GARBAGE
							stty -echo
							echo -en ,"\e[1A\e[?25l"
							if [ -n "$GARBAGE" ] || [[ "$PHRASE" =~ [,] ]]; then
								error "Need 1 phrase without spaces or commas."
