							elif [ -z "$PHRASE" ]; then
								success "Empty. Finishing."
								break
							else
								success "Pattern $CYCLE: $PHRASE"
								PHRASE="$PHRASE,"
								PATTERNS="${PHRASE}${PATTERNS}"
							fi
							if ! $ERROR; then ((CYCLE++)); fi
						done
						success "Got $((CYCLE-1)) patterns: $PATTERNS"
						if [ -z "$PATTERNS" ]; then
							error "Empty..."
							exit 1
						fi
						DO_SAVE=true
						SEARCH_PATTERN="$PATTERNS"
