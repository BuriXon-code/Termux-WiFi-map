# Jitter for KML
jitter_pair() {
	local bssid="$1"
	local seed
	seed=$(printf "%s" "$bssid" | cksum | awk '{print $1}')
	local a=$(( (seed % 1001) - 500 ))
	local b=$(( ((seed/7) % 1001) - 500 ))
	local dlat dlng
	dlat=$(awk -v n="$a" 'BEGIN{printf "%.7f", n/10000000}')
	dlng=$(awk -v n="$b" 'BEGIN{printf "%.7f", n/10000000}')
	printf "%s;%s" "$dlat" "$dlng"
}
# Save kml
save_kml() {
	local tmp="$SAVE_FILE.tmp"
	: > "$tmp"
	exec 3> "$tmp"
	{
		echo '<?xml version="1.0" encoding="UTF-8"?>' >&3
		echo '<kml xmlns="http://www.opengis.net/kml/2.2"><Document>' >&3
		echo "	<name>$SAVE_KML_NAME</name>" >&3
		echo '	<Style id="open"><IconStyle><Icon><href>http://maps.google.com/mapfiles/kml/paddle/grn-blank.png</href></Icon></IconStyle></Style>' >&3
		echo '	<Style id="lock"><IconStyle><Icon><href>http://maps.google.com/mapfiles/kml/paddle/red-blank.png</href></Icon></IconStyle></Style>' >&3
		echo '	<Style id="cache"><IconStyle><Icon><href>http://maps.google.com/mapfiles/kml/paddle/ylw-blank.png</href></Icon></IconStyle></Style>' >&3
	}
	CURRENT=0
	TOTAL=$(wc -l < "$CACHE_FILE")
	echo -en "\e[?7l"
	while IFS= read -r row; do
		CURRENT=$((CURRENT + 1))

		echo "$row" | jq -c '.' &>/dev/null || {
			error "Invalid/corrupted cache file: line $CURRENT\e[J"
			info "Skipped...\n"
			sleep 0.1
			continue
		}

		local ssid bssid caps time lat lon alt api
		ssid=$(echo "$row" | jq -r '(.ssid//"(hidden)")' 2>/dev/null)
		bssid=$(echo "$row" | jq -r '.bssid' 2>/dev/null)
		caps=$(echo "$row" | jq -r '(.capabilities//"")' 2>/dev/null)
		time=$(echo "$row" | jq -r '.time' 2>/dev/null)
		lat=$(echo "$row" | jq -r '.latitude' 2>/dev/null)
		lon=$(echo "$row" | jq -r '.longitude' 2>/dev/null)
		alt=$(echo "$row" | jq -r '(.altitude//0)' 2>/dev/null)
		api=$(echo "$row" | jq -r 'if .api == false then "false" else "true" end' 2>/dev/null)

		cols=$(tput cols)
		[ "$cols" -lt 1 ] && cols=1

		[ -z "$lat" ] || [ -z "$lon" ] && continue

		IFS=';' read -r jl jg <<<"$(jitter_pair "$bssid")"
		jlat=$(awk -v a="$lat" -v b="$jl" 'BEGIN{printf "%.8f", a+b}')
		jlon=$(awk -v a="$lon" -v b="$jg" 'BEGIN{printf "%.8f", a+b}')

		if is_locked "$caps"; then style="#lock"; color="\e[1;31m"; else style="#open"; color="\e[1;32m"; fi
		[ "$api" = "false" ] && { style="#cache"; color="\e[1;33m"; }


		if [ -z "$ssid" ] || [ "$ssid" = "(hidden)" ]; then
			echo -e "\e[1A\r\e[K"
			echo -en "\e[1;33m[$((CURRENT * 100 / TOTAL))%]$color [SSID]\e[0m:\e[K \e[2m(hidden)\e[0m"
		else
			echo -e "\e[1A\r\e[K"
			echo -en "\e[1;33m[$((CURRENT * 100 / TOTAL))%]$color [SSID]\e[0m:\e[K ${ssid:0:$((cols-15))}"
		fi

		{
			echo "	<Placemark>"
			echo "		<name><![CDATA[$ssid]]></name>"
			echo "		<description><![CDATA[$bssid | $caps | $time]]></description>"
			echo "		<styleUrl>$style</styleUrl>"
			echo "		<Point><coordinates>$jlon,$jlat,$alt</coordinates></Point>"
			echo "	</Placemark>"
		} >&3
	done < <(cat "$CACHE_FILE" 2>/dev/null) || {
		exec 3>&-
		error "Aborted."
		error "Invalid/corrupted cache file: line $CURRENT"
		rm -f "$tmp"
		exit 1
	}

	echo '</Document></kml>' >&3
	exec 3>&-
	mv "$tmp" "${SAVE_FILE}.${SAVE_EXT}" || { error "Save failed"; exit 1; }

	success "File saved: ${SAVE_FILE}.${SAVE_EXT}"
}
# Save method
do_save() {
	if [ $# -eq 2 ]; then
		CACHE_FILE="$1"
		SAVE_FMT="$2"
		if [ -n "$SEARCH_PATTERN" ]; then
			SAVE_FILE="$SEARCH_PATTERN"
			SAFE_SEARCH="${SEARCH_PATTERN//[^a-zA-Z0-9._-]/_}"
			SAVE_FILE="$SAFE_SEARCH"
		elif [ -n "$SEARCH_VENDOR" ]; then
			SAFE_VENDOR="${SEARCH_VENDOR//[^a-zA-Z0-9._-]/_}"
			SAVE_FILE="$SAFE_VENDOR"
		else
			SAVE_FILE="output"
		fi
		SAVE_OVERRIDE=true
	fi
	[ -s "$CACHE_FILE" ] || { error "Cache empty: try to scan first."; exit 1; }
	case "$SAVE_FMT" in
		json)
			SAVE_EXT="json"
			check_file_exists
			save_json_min
			;;
		pjson)
			SAVE_EXT="json"
			check_file_exists
			save_json_pretty
			;;
		jsonl)
			SAVE_EXT="jsonl"
			check_file_exists
			save_json_list
			;;
		csv)
			SAVE_EXT="csv"
			check_file_exists
			save_csv
			;;
		kml)
			SAVE_EXT="kml"
			check_file_exists
			save_kml
			;;
		*)
			error "Unknown format: $SAVE_FMT"
			exit 1
			;;
	esac
	exit 0
}
