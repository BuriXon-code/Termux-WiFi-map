								info "Try to use -h|--help for more info."
								exit 1
							elif [ $# -lt 2 ]; then
								error "The required parameter is missing."
								info "Try to use -h|--help for more info."
								exit 1
							fi
							for arg in "$@"; do
								case "$arg" in
									-*)
										error "Invalid parameter: $1"
										info "Try to use -h|--help for more info."
										exit 1
										;;
								esac
							done
							MERGE_1="$1"
							MERGE_2="$2"
							shift 2
							DO_MERGE=true
							;;
						-v|--valid)
							shift
							if [ $# -gt 1 ]; then
								error "Too many parameters."
								info "Try to use -h|--help for more info."
								exit 1
							elif [ $# -lt 1 ]; then
								error "The required parameter is missing."
								info "Try to use -h|--help for more info."
								exit 1
							fi
							VALID_FILE="$1"
							shift
							DO_VALID=true
							;;
						-c|--convert)
							shift
							if [ $# -gt 1 ]; then
								error "Too many parameters."
								info "Try to use -h|--help for more info."
								exit 1
							elif [ $# -lt 1 ]; then
								error "The required parameter is missing."
								info "Try to use -h|--help for more info."
								exit 1
							fi
							SAVE_FMT="kml"
							SAVE_EXT="kml"
							CACHE_FILE="$1"
							SAVE_FILE="${1%.*}"
							shift
							DO_CONVERT=true
							;;
						-*|*)
							error "Invalid parameter: $1"
							info "Try to use -h|--help for more info."
							exit 1
							;;
					esac
				done
				;;
			-h|--help)
				show_help
				;;
			-v|--version)
				version_info
				exit 0
				;;
			-i|--version-info)
				about_info
				;;
			-u|--check-update)
				check_update false true
				exit $?
				;;
			-b|--banner)
				banner
				exit $?
				;;
			-r|--report)
				info "Please provide as much detail as possible."
				error "I will ignore messages that are not detailed." >&1
				info "Selecting browser..."
				sleep 1
				open_page $SCRIPT_REPORT
				success "Done."
				exit 0
				;;
			*)
				if [ $# -eq 1 ]; then
					if [ -f "$CACHE_DIR/alias/$1.alias" ]; then
						alias_run $1
					else
						error "Invalid parameter: $1"
						info "Try to use -h|--help for more info."
						exit 1
					fi
				else
					error "Invalid parameter: $1"
					info "Try to use -h|--help for more info."
					exit 1
				fi
				;;
		esac
	done
